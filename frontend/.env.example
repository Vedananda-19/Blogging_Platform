# Copy to `.env.development` (local) / `.env.production` (build). Baked in at build time.
#   VITE_API_URL local: http://localhost:8000   prod: https://your-backend.onrender.com
VITE_API_URL="http://localhost:8000"

# Firebase web API key (Firebase console -> Project settings -> Web app).
# Not a secret — web API keys are public identifiers, restricted by Firebase rules/domains.
VITE_FIREBASE_API_KEY="your-firebase-web-api-key"
