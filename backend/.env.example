# Copy this file to `.env` and fill in real values. Never commit the real `.env`.

# Database — SQLite for local dev, or a Postgres URL in production (Neon/Render).
#   local:  sqlite:///./data/app.db
#   prod:   postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL="sqlite:///./data/app.db"

# Secret for signing JWTs. Generate a strong one:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY="change-me"

# Google OAuth client ID (public) used to verify Google sign-in tokens.
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"

# Cloudinary — image uploads (dashboard -> Settings -> API Keys).
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
